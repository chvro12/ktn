# Base de données (PostgreSQL)
# Exemple compatible avec `docker compose` à la racine du dépôt
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/katante"

# API (serveur applicatif)
API_PORT=4000
API_HOST=0.0.0.0
# Une origine ou plusieurs séparées par des virgules. En prod : https://ton-site.vercel.app
# Pour les previews Vercel (URL *.vercel.app), mets aussi CORS_ALLOW_VERCEL_PREVIEWS=1 sur l’API.
CORS_ORIGIN=http://localhost:3000
# CORS_ALLOW_VERCEL_PREVIEWS=1
COOKIE_SECRET="change-me-min-32-chars-production-secret-key"

# Site web (variables publiques côté navigateur)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stockage et diffusion des médias (voir README)
# MEDIA_ROOT=
# PUBLIC_MEDIA_BASE_URL=http://localhost:4000
# MEDIA_SKIP_TRANSCODE=1
